<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="oop.project.hrs.ui.ReservationPaymentController"
           prefHeight="400.0" prefWidth="600.0">

    <VBox fx:id="reservationView" spacing="10" alignment="CENTER" style="-fx-padding: 20;">
        <Label text="Reservation History" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
        </TableView>

        <HBox spacing="10" alignment="CENTER">
            <Button text="New Reservation" onAction="#handleNewReservation"/>
            <Button text="Cancel Selected" onAction="#handleCancelReservation"/>
            <Button text="Proceed to Payment" onAction="#showPaymentScreen"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
        </HBox>
    </VBox>

    <GridPane fx:id="paymentView" hgap="10" vgap="15" alignment="CENTER" visible="false">
        <Label text="Checkout &amp; Payment" GridPane.columnSpan="2"
               style="-fx-font-size: 20; -fx-font-weight: bold;"/>

        <Label text="Total Amount:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="totalAmountLabel" text="0.00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Payment Method:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="paymentMethodBox" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <HBox spacing="10" GridPane.rowIndex="3" GridPane.columnSpan="2" alignment="CENTER">
            <Button text="Back" onAction="#showReservationScreen"/>
            <Button text="Confirm Payment" onAction="#handleConfirmPayment"
                    style="-fx-background-color: #f1c40f; -fx-text-fill: black;"/>
        </HBox>
    </GridPane>

</StackPane>