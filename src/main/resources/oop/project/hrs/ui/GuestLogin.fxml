      <Hyperlink layoutX="502.0" layoutY="353.0" text="Staff Login" />
      <StackPane layoutX="6.0" layoutY="230.0" prefHeight="26.0" prefWidth="562.0">
         <children>
            <Text fx:id="errorText" fill="RED" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-border-color: red;" text="ERROR" textAlignment="CENTER" visible="false" />
