<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="oop.project.hrs.ui.GuestAuthController">
   <children>
      <PasswordField fx:id="passwordField" layoutX="226.0" layoutY="187.0" />
